# Generated by autotape — profile "tui"
# Defaults measured from real published tapes (data/extracted-defaults.json)
Output demo.gif
Require htop
Set FontSize 16
Set Width 1600
Set Height 900
Set Padding 16
Set Framerate 30
Set TypingSpeed 100ms
Set Theme "Catppuccin Mocha"
Set CursorBlink false

Type "htop -u root"
Enter
Sleep 2s
Down@400ms 3
Sleep 1s
Type "t"
Sleep 1500ms
Type "/"
Sleep 500ms
Type "root"
Sleep 1500ms
Escape
Sleep 1s
Space
Sleep 3s
